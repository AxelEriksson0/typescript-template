{
  "extends": "../../tsconfig.json",
  "exclude": ["dist", "node_modules", "paraglide"],
  "include": ["**/*.ts", "**/*.tsx", "*.ts", "*.tsx", "*.js", "**/*.js"],
  "compilerOptions": {
    "allowJs": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist"
  }
}
