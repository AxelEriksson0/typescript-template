{
  "name": "simple-function-and-test",
  "description": "This includes a simple function and a test. Use as a template for creating new packages.",
  "type": "module",
  "scripts": {
    "build": "tsgo",
    "dev": "node ./index.ts",
    "start": "node ./index.ts",
    "ut": "node --experimental-test-coverage --coverage-reporter=text --coverage-reporter=lcov --test **/*.test.ts",
    "watch": "tsgo -w"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260317.1",
    "solid-js": "^1.9.11"
  }
}
