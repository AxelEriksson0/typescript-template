{
  "engines": {
    "node": ">=17.8.0"
  },
  "type": "module",
  "name": "typescript-template",
  "version": "1.4.0",
  "description": "My opinionated TypeScript + ESLint template",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "start": "node build/index.js",
    "ut": "jest ./src",
    "test": "npm run lint && npm run ut",
    "watch": "tsc -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AxelEriksson0/typescript-template.git"
  },
  "keywords": [
    "eslint",
    "typescript"
  ],
  "author": "Axel Eriksson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AxelEriksson0/typescript-template/issues"
  },
  "homepage": "https://github.com/AxelEriksson0/typescript-template#readme",
  "devDependencies": {
    "@types/jest": "^27.4.1",
    "@types/node": "^17.0.23",
    "@types/uuid": "^8.3.3",
    "@typescript-eslint/eslint-plugin": "^5.7.0",
    "@typescript-eslint/parser": "^5.7.0",
    "eslint": "^8.4.1",
    "eslint-plugin-ban": "^1.6.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "jest": "^27.5.1",
    "ts-jest": "^27.1.4",
    "ts-node": "^10.7.0",
    "typescript": "^4.7.0-beta"
  },
  "dependencies": {
    "uuid": "^8.3.2"
  }
}
