{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint",
        "ban",
        "unused-imports"
    ],
    "rules": {
        "ban/ban": [
            "error",
            {
                "name": [
                    "it",
                    "only"
                ],
                "message": "Don't focus tests"
            }
        ],
        "semi": [
            "error",
            "never"
        ],
        "sort-imports": [
            "error",
            {
                "ignoreCase": false,
                "ignoreDeclarationSort": false,
                "ignoreMemberSort": false,
                "memberSyntaxSortOrder": [
                    "none",
                    "all",
                    "multiple",
                    "single"
                ],
                "allowSeparatedGroups": false
            }
        ],
        "unused-imports/no-unused-imports-ts": "error"
    }
}